   "source": [
    "records = []\n",
    "for item in data1.get(\"results\",[]):\n",
    "    patient = item.get(\"patient\", {})\n",
    "\n",
    "    age = patient.get(\"patientonsetage\")\n",
    "    sex = patient.get(\"patientsex\")\n",
    "    weight = patient.get(\"patientweight\")\n",
    "    unit = patient.get(\"patientonsetageunit\")\n",
    "\n",
    "    reaction = patient.get(\"reaction\",[])\n",
    "    reaction_list = [r.get(\"reactionmeddrapt\") for r in reaction]\n",
    "\n",
    "    drugs = patient.get(\"drug\", [])\n",
    "    drug_names = [d.get(\"medicinalproduct\") for d in drugs if d.get(\"medicinalproduct\")]\n",
    "\n",
    "    routes = [d.get(\"drugadministrationroute\") for d in drugs]\n",
    "\n",
    "    records.append(\n",
    "        {\n",
    "            \"age\": age,\n",
    "            \"sex\": sex,\n",
    "            \"weight\" : weight,\n",
    "            \"unit\" : unit,\n",
    "            \"reaction\" : reaction_list,\n",
    "            \"drug_names\": drug_names,\n",
    "            \"routes\": routes\n",
    "        }\n",
    "    )\n",
    "\n",
    "df1 = pd.DataFrame(records)\n",
    "df1.head()"
   ]
