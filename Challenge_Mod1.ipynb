    "#Visualize the data as a heatmap\n",
    "#TODO\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# Step 1: explode both columns\n",
    "df_routes = df_nitro.explode(\"routes\").explode(\"reaction\")\n",
    "\n",
    "# Step 2: remove nulls\n",
    "df_routes = df_routes[\n",
    "    df_routes[\"routes\"].notna() &\n",
    "    df_routes[\"reaction\"].notna()\n",
    "]\n",
    "\n",
    "# Step 3: create pivot table (THIS creates heatmap_data)\n",
    "heatmap_data = df_routes.groupby(\n",
    "    [\"routes\", \"reaction\"]\n",
    ").size().unstack(fill_value=0)\n",
    "\n",
    "# Step 4: heatmap\n",
    "plt.figure(figsize=(12, 6))\n",
    "\n",
    "sns.heatmap(\n",
    "    heatmap_data,\n",
    "    cmap=\"YlOrRd\"\n",
    ")\n",
    "\n",
    "plt.title(\"Nitroglycerin: Route vs Reaction Heatmap\")\n",
    "plt.xlabel(\"Reaction\")\n",
    "plt.ylabel(\"Route\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
