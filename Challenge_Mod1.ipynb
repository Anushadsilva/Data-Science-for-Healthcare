    "#Convert all age entries to years\n",
    "#TODO\n",
    "\n",
    "def convert_to_age(row):\n",
    "    age = row[\"age\"]\n",
    "    unit = row.get(\"unit\")\n",
    "\n",
    "    if pd.isna(age):\n",
    "        return None\n",
    "    \n",
    "    if unit == \"800\":\n",
    "        return age * 10\n",
    "    elif unit == \"801\":\n",
    "        return age\n",
    "    elif unit == \"802\":\n",
    "        return age / 12\n",
    "    elif unit == \"803\":\n",
    "        return age/ 52\n",
    "    elif unit ==\"804\":\n",
    "        return age / 365\n",
    "    elif unit == \"805\":\n",
    "        return age / (365 * 24)\n",
    "    else:\n",
    "        return None \n",
    "\n",
    "df[\"age_years\"] = df.apply(convert_to_age, axis =1)\n",
    "df.head()\n",
    "\n"
   ]
