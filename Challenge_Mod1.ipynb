    "adult_df = df_clean[df_clean[\"age_years\"] >= 18].copy()\n",
    "\n",
    "adult_df[\"age_group\"] = pd.cut(adult_df[\"age_years\"], bins = bins , labels = labels)\n",
    "\n",
    "adult_df.head()"
